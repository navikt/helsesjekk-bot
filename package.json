{
    "name": "helsesjekk",
    "version": "1.0.0",
    "license": "MIT",
    "type": "module",
    "packageManager": "yarn@4.16.0",
    "dependenciesMeta": {
        "@prisma/engines": {
            "built": true
        }
    },
    "engines": {
        "node": "24"
    },
    "scripts": {
        "dev": "next dev | pino-pretty --messageKey=message",
        "dev:db": "docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 -it postgres:14",
        "build": "next build",
        "start": "next start",
        "lint": "eslint src",
        "test": "vitest",
        "start:migrate": "yarn prisma:migrate && yarn start",
        "prisma:generate": "prisma generate && yarn prettier --write src/db/generated/**/*.{ts,mjs}",
        "prisma:migrate": "NODE_OPTIONS='-r next-logger' prisma migrate deploy",
        "prisma:migrate-dev": "prisma migrate dev",
        "prisma:seed": "node --env-file=.env --env-file=.env.development --import tsx/esm seed/seed.ts | pino-pretty --messageKey=message",
        "postinstall": "command -v husky && husky || true"
    },
    "dependencies": {
        "@navikt/aksel-icons": "^7.40.0",
        "@navikt/ds-css": "^7.40.0",
        "@navikt/ds-react": "^7.40.0",
        "@navikt/ds-tailwind": "^7.40.0",
        "@navikt/next-logger": "^5.0.0",
        "@navikt/oasis": "^4.1.4",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "7.8.0",
        "@slack/bolt": "^4.7.3",
        "@slack/logger": "^4.0.1",
        "@slack/types": "^2.21.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.4.0",
        "dotenv": "^17.4.2",
        "next": "^16.2.7",
        "next-logger": "^5.0.2",
        "nextleton": "^0.6.1",
        "node-cron": "^4.5.0",
        "nuqs": "^2.8.9",
        "pino": "^10.3.1",
        "postcss": "^8.5.15",
        "prisma": "7.8.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "recharts": "3.1.2",
        "remeda": "^2.39.0",
        "sharp": "^0.34.5",
        "tailwind-merge": "^3.6.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@navikt/tsm-eslint-react": "^1.0.0",
        "@navikt/tsm-prettier": "^2.0.0",
        "@tailwindcss/postcss": "^4.3.0",
        "@types/node": "^24.13.1",
        "@types/node-cron": "^3.0.11",
        "@types/react": "19.2.17",
        "@vercel/nft": "^1.10.2",
        "eslint": "^9.39.4",
        "eslint-config-next": "16.2.7",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.4",
        "prettier-plugin-prisma": "^5.0.0",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    },
    "prettier": "@navikt/tsm-prettier"
}
